generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  FREE
  PRO
}

model BillingSubscription {
  id                   String              @id @default(cuid())
  clerkUserId          String              @unique
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  subscriptionStatus   SubscriptionStatus  @default(FREE)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

/// Records Stripe webhook event IDs so deliveries are processed at most once.
model StripeProcessedWebhookEvent {
  stripeEventId String   @id
  eventType     String
  createdAt     DateTime @default(now())
}

// --- Question bank (Step 2 content) ---

model ExamSource {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id                   String              @id @default(cuid())
  examSourceId         String
  examSource           ExamSource          @relation(fields: [examSourceId], references: [id], onDelete: Cascade)
  questionNumber       Int
  stem                 String              @db.Text
  correctAnswer        String
  explanation          String              @db.Text
  educationalObjective String              @db.Text
  topic                String?
  difficulty           QuestionDifficulty?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  choices              QuestionChoice[]

  @@unique([examSourceId, questionNumber])
  @@index([examSourceId])
}

model QuestionChoice {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  text       String   @db.Text
  sortOrder  Int      @default(0)

  @@unique([questionId, label])
  @@index([questionId, sortOrder])
}
